# League Pro - Environment Configuration

# ============================================================================
# SUPABASE
# ============================================================================
# Get these from your Supabase project settings:
# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Project Settings > API > Project API keys > service_role (KEEP SECRET!)
# Only use this in server-side code, API routes, or Server Actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# APPLICATION
# ============================================================================
# Base URL for your application (production URL when deployed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: DEVELOPMENT
# ============================================================================
# Enable debug logging in development
# NEXT_PUBLIC_DEBUG=true
